# LangFuse Tracing Configuration (Self-Hosted Recommended)
# For self-hosted: Deploy with docker-compose (see docs/LANGFUSE_SELFHOSTED.md)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# For LangFuse Cloud (alternative):
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk_prod_xxxxx
# LANGFUSE_SECRET_KEY=sk_prod_xxxxx

# For Production Self-Hosted with HTTPS:
# LANGFUSE_HOST=https://langfuse.yourdomain.com
# LANGFUSE_PUBLIC_KEY=pk_xxxxx
# LANGFUSE_SECRET_KEY=sk_xxxxx

# Core graph pipeline
CHUNK_SIZE_WORDS=180
CHUNK_OVERLAP_WORDS=30
EMBED_DIM=256

# Gemini integration
GOOGLE_API_KEY=
USE_GEMINI_EXTRACTION=0
EMBED_MODEL=models/gemini-embedding-2-preview
EXTRACT_MODEL=gemini-2.0-flash
REASON_MODEL=gemini-2.5-pro

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# Extraction thresholds
MAX_RETRY_CYCLES=2
MIN_CONFIDENCE=0.70
